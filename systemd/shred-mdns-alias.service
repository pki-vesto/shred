[Unit]
Description=Publish shred.frodo.local mDNS alias for Shred Tracker
Documentation=file:///home/peter/shred/README.md
Requires=avahi-daemon.service
After=avahi-daemon.service network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/avahi-publish -a -R shred.frodo.local 192.168.1.111
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
